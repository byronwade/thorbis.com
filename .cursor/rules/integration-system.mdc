## 🔒 Security Implementation

### Zero Trust Permission Validation
```typescript
// REQUIRED: Permission validation middleware
export class IntegrationPermissionValidator {
  static async validateAccess(
    userId: string,
    integrationId: string,
    action: string,
    context: AccessContext
  ): Promise<AccessResult> {
    const startTime = performance.now();
    
    try {
      // 1. Get user and integration details
      const user = await getUserById(userId);
      const integration = await getIntegrationById(integrationId);
      
      if (!user || !integration) {
        return { allowed: false, reason: 'User or integration not found' };
      }
      
      // 2. Check integration is enabled
      if (!integration.config.enabled) {
        return { allowed: false, reason: 'Integration disabled' };
      }
      
      // 3. Get user's permissions for this integration
      const permissions = await getUserIntegrationPermissions(userId, integrationId);
      
      // 4. Validate specific action
      const actionPermission = permissions.actions[action];
      if (!actionPermission?.enabled) {
        return { allowed: false, reason: 'Action not permitted' };
      }
      
      // 5. Check attribute-based conditions
      const attributeCheck = await validateAttributeConditions(
        actionPermission.conditions || [],
        context
      );
      
      if (!attributeCheck.allowed) {
        return attributeCheck;
      }
      
      // 6. Log access attempt
      await logAccessAttempt({
        userId,
        integrationId,
        action,
        allowed: true,
        context,
        timestamp: new Date(),
        responseTime: performance.now() - startTime
      });
      
      return { allowed: true, permissions: actionPermission };
      
    } catch (error) {
      logger.error('Permission validation error:', error);
      return { allowed: false, reason: 'Validation error' };
    }
  }
}
```

### Audit Trail System
```typescript
// REQUIRED: Comprehensive audit logging
interface AuditLog {
  id: string;
  timestamp: Date;
  userId: string;
  integrationId: string;
  action: string;
  result: 'success' | 'denied' | 'error';
  reason?: string;
  context: {
    ipAddress: string;
    userAgent: string;
    location?: string;
    device?: string;
  };
  dataAccessed?: {
    type: string;
    recordIds: string[];
    fieldsAccessed: string[];
  };
}

export class AuditLogger {
  static async logPermissionChange(change: PermissionChange): Promise<void> {
    await supabase.from('audit_logs').insert({
      type: 'permission_change',
      user_id: change.changedBy,
      target_user_id: change.targetUserId,
      integration_id: change.integrationId,
      old_permissions: change.oldPermissions,
      new_permissions: change.newPermissions,
      reason: change.reason,
      timestamp: new Date().toISOString()
    });
  }
  
  static async logAccessAttempt(attempt: AccessAttempt): Promise<void> {
    await supabase.from('audit_logs').insert({
      type: 'access_attempt',
      user_id: attempt.userId,
      integration_id: attempt.integrationId,
      action: attempt.action,
      result: attempt.allowed ? 'success' : 'denied',
      context: attempt.context,
      timestamp: new Date().toISOString()
    });
  }
}
```

## 📋 Implementation Checklist

### For Every New Integration:

#### Structure Requirements:
- [ ] Follows standard integration interface
- [ ] Implements all required permission categories
- [ ] Has proper error handling and rollback
- [ ] Includes comprehensive documentation
- [ ] Has header visibility configured

#### Permission Requirements:
- [ ] Implements RBAC with at least 4 role levels
- [ ] Has granular action permissions
- [ ] Includes attribute-based restrictions
- [ ] Has audit logging for all actions
- [ ] Business owner can control all permissions

#### UI Requirements:
- [ ] Appears in header when enabled (default: true)
- [ ] Has intuitive permission management interface
- [ ] Shows clear permission descriptions
- [ ] Has quick toggle functionality
- [ ] Provides permission change notifications

#### Security Requirements:
- [ ] Implements zero trust validation
- [ ] Has proper input sanitization
- [ ] Includes rate limiting
- [ ] Has secure credential storage
- [ ] Logs all security events

#### Business Owner Controls:
- [ ] Role assignment matrix
- [ ] Individual permission overrides
- [ ] Bulk permission management
- [ ] Permission change history
- [ ] Compliance reporting

### Required Database Schema:
```sql
-- Integration permissions table
CREATE TABLE integration_permissions (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    business_id UUID NOT NULL REFERENCES businesses(id),
    user_id UUID NOT NULL REFERENCES users(id),
    integration_id TEXT NOT NULL,
    role TEXT NOT NULL,
    permissions JSONB NOT NULL,
    restrictions JSONB DEFAULT '{}',
    created_at TIMESTAMPTZ DEFAULT NOW(),
    updated_at TIMESTAMPTZ DEFAULT NOW(),
    created_by UUID REFERENCES users(id),
    
    UNIQUE(business_id, user_id, integration_id)
);

-- Permission audit log
CREATE TABLE permission_audit_log (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    business_id UUID NOT NULL REFERENCES businesses(id),
    user_id UUID REFERENCES users(id),
    target_user_id UUID REFERENCES users(id),
    integration_id TEXT NOT NULL,
    action TEXT NOT NULL,
    old_permissions JSONB,
    new_permissions JSONB,
    context JSONB DEFAULT '{}',
    timestamp TIMESTAMPTZ DEFAULT NOW()
);

-- Access attempt log
CREATE TABLE access_audit_log (
    id UUID PRIMARY KEY DEFAULT uuid_generate_v4(),
    user_id UUID NOT NULL REFERENCES users(id),
    integration_id TEXT NOT NULL,
    action TEXT NOT NULL,
    result TEXT NOT NULL CHECK (result IN ('success', 'denied', 'error')),
    context JSONB DEFAULT '{}',
    data_accessed JSONB,
    timestamp TIMESTAMPTZ DEFAULT NOW()
);
```

