  category = IntegrationCategory.COMMUNICATION;
  
  config = {
    enabled: true,
    defaultEnabled: true,
    apiEndpoint: process.env.INTEGRATION_API_ENDPOINT,
    version: '1.0.0',
    lastSync: new Date()
  };
  
  permissions = {
    roles: {
      admin: { /* full permissions */ },
      manager: { /* limited admin */ },
      employee: { /* basic operations */ },
      viewer: { /* read-only */ },
      custom: []
    },
    actions: {
      canView: { enabled: true, auditLevel: 'basic', description: 'View integration data' },
      canCreate: { enabled: false, auditLevel: 'detailed', description: 'Create new records' },
      // ... other permissions
    },
    attributes: {
      timeRestrictions: [],
      locationRestrictions: [],
      deviceRestrictions: [],
      dataTypeRestrictions: []
    }
  };
  
  ui = {
    icon: 'integration-icon',
    color: '#007bff',
    headerVisible: true,
    position: 10
  };
  
  handlers = {
    onEnable: async () => {
      // Enable integration logic
      await this.validateConfiguration();
      await this.initializeConnection();
      await AuditLogger.logIntegrationChange('enabled', this.id);
    },
    
    onDisable: async () => {
      // Disable integration logic
      await this.cleanupConnections();
      await AuditLogger.logIntegrationChange('disabled', this.id);
    },
    
    onPermissionChange: async (changes: PermissionChange[]) => {
      // Handle permission changes
      for (const change of changes) {
        await this.updateUserPermissions(change);
        await AuditLogger.logPermissionChange(change);
      }
    }
  };
}
```

