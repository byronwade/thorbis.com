## 🔄 Utility Function Templates

### Performance Utility Template
```typescript
// utils/performance.ts
export const measurePerformance = <T>(
  fn: () => T,
  label: string
): T => {
  const start = performance.now();
  const result = fn();
  const duration = performance.now() - start;
  
  console.log(`${label} took ${duration.toFixed(2)}ms`);
  return result;
};

export const debounce = <T extends (...args: any[]) => void>(
  func: T,
  wait: number
): T => {
  let timeout: NodeJS.Timeout;
  return ((...args: any[]) => {
    clearTimeout(timeout);
    timeout = setTimeout(() => func.apply(null, args), wait);
  }) as T;
};
```

### Data Processing Utilities
```typescript
// utils/data.ts
import { groupBy, sortBy, uniqBy } from 'lodash';

export const processData = <T>(
  data: T[],
  options: {
    groupKey?: keyof T;
    sortKey?: keyof T;
    uniqueKey?: keyof T;
  }
) => {
  let processed = data;
  
  if (options.uniqueKey) {
    processed = uniqBy(processed, options.uniqueKey);
  }
  
  if (options.sortKey) {
    processed = sortBy(processed, options.sortKey);
  }
  
  if (options.groupKey) {
    return groupBy(processed, options.groupKey);
  }
  
  return processed;
};
```

### Validation Utilities
```typescript
// utils/validation.ts
export const isValidEmail = (email: string): boolean => {
  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  return emailRegex.test(email);
};

export const isValidURL = (url: string): boolean => {
  try {
    new URL(url);
    return true;
  } catch {
    return false;
  }
};

export const sanitizeString = (str: string): string => {
  return str
    .trim()
    .replace(/[<>]/g, '') // Remove potential XSS characters
    .slice(0, 1000); // Limit length to prevent DoS
};
```

## 📦 Configuration Management

### Environment-Specific Configuration
```typescript
// utils/config.ts
export const config = {
  isDevelopment: process.env.NODE_ENV === 'development',
  isProduction: process.env.NODE_ENV === 'production',
  isTest: process.env.NODE_ENV === 'test',
  
  // API Configuration
  apiUrl: process.env.NEXT_PUBLIC_API_URL || 'http://localhost:3000',
  apiTimeout: parseInt(process.env.API_TIMEOUT || '5000', 10),
  
  // Feature Flags
  enableAnalytics: process.env.NEXT_PUBLIC_ENABLE_ANALYTICS === 'true',
  enableExperimentalFeatures: process.env.NEXT_PUBLIC_ENABLE_EXPERIMENTAL === 'true',
  
  // Database
  databaseUrl: process.env.DATABASE_URL,
  maxConnections: parseInt(process.env.DB_MAX_CONNECTIONS || '10', 10),
};
```

### Logging Configuration
```typescript
// utils/logger.ts
export const logger = {
  debug: (message: string, data?: any) => {
    if (config.isDevelopment) {
      console.log(`[DEBUG] ${message}`, data);
    }
  },
  
  info: (message: string, data?: any) => {
    console.info(`[INFO] ${message}`, data);
  },
  
  warn: (message: string, data?: any) => {
    console.warn(`[WARN] ${message}`, data);
  },
  
  error: (message: string, error?: any) => {
    console.error(`[ERROR] ${message}`, error);
    
    // Send to external logging service in production
    if (config.isProduction) {
      // sendToLoggingService(message, error);
    }
  },
};
```

## 🚀 Development Best Practices

### DO:
- Use descriptive variable and function names
- Implement proper error handling
- Add TypeScript types for better development experience
- Use environment variables for configuration
- Follow established code patterns
- Optimize for performance
- Add proper logging

### DON'T:
- Hard-code configuration values
- Skip error handling
- Use `any` type in TypeScript
- Create duplicate utility functions
- Ignore performance implications
- Skip documentation for complex functions

### Performance Considerations:
- Import only what you need from libraries
- Use lazy loading for heavy utilities
- Implement caching where appropriate
- Monitor bundle size impact
- Use memoization for expensive computations

**Remember: Good utilities and configuration make the codebase maintainable and scalable.**