# ================================
# SECURITY: Prevent sensitive files from entering Docker context
# ================================

# Environment files (CRITICAL SECURITY)
.env*
!.env.example
*.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Secrets and credentials
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
credentials/

# Development files
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
bun.lockb

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Git files
.git/
.gitignore
README.md
CHANGELOG.md
*.md

# Test files
coverage/
.nyc_output/
.jest/
__tests__/
*.test.js
*.test.ts
*.spec.js
*.spec.ts

# Build artifacts (will be recreated)
.next/
out/
build/
dist/

# Cache directories
.cache/
.parcel-cache/
.eslintcache

# Logs
logs/
*.log

# Temporary files
tmp/
temp/
.tmp/

# Documentation
docs/
*.md
LICENSE

# Development tools
.prettierrc*
.eslintrc*
.stylelintrc*
.editorconfig
.gitattributes
.husky/

# Package manager files (keep essential ones)
yarn.lock
pnpm-lock.yaml
.npmrc
.yarnrc
.yarnrc.yml

# Vercel and deployment
.vercel/
.next/
out/

# Testing
cypress/
e2e/
playwright/
.playwright/

# Storybook
.storybook/
storybook-static/

# Database
*.db
*.sqlite
*.sqlite3

# Docker files (don't nest Docker contexts)
Dockerfile*
docker-compose*.yml
.dockerignore

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
.circleci/

# Local development
scripts/data-collection/
tests/
voip-popover/
